#!/bin/bash

# Only run on macOS
{{ if eq .chezmoi.os "darwin" -}}

# Brewfile hash: {{ include "dot_Brewfile" | sha256sum }}
echo "📦 Brewfile changed. Syncing packages..."

if command -v brew &> /dev/null; then
    # Ensure Homebrew is in the path for this script session
    if [[ $(uname -m) == "arm64" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
    
    # Run brew bundle using the .Brewfile in your home directory
    brew bundle --global --cleanup
    echo "✅ Homebrew packages synced."
else
    echo "❌ Homebrew not found. Skipping package sync."
fi

{{ end -}}
