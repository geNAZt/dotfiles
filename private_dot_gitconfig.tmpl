[user]
	name = {{ .name }}
	email = {{ .email }}
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINOQU0exRp2wED2T3fJAY1iZLg+lFNli2GEOj9aBL123
[commit]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	autocrlf = input
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
