#!/bin/bash

# 1. Ensure the 1Password CLI is installed
if ! command -v op &> /dev/null; then
    echo "1Password CLI (op) not found. Installing via Homebrew..."
    brew install 1password-cli
fi

# 2. Define the account from your chezmoi data
MY_EMAIL="{{ .email }}"
ACCOUNT_SHORTHAND="flamingo"  # You can change this to your preference
ENCRYPTED_KEY="{{ .chezmoi.sourceDir }}/encrypted_secret_key.age"

# 3. Check if the account is already configured
if op account list | grep -q "$MY_EMAIL"; then
    echo "✓ 1Password account ($MY_EMAIL) is already configured."
else
    echo "Adding 1Password account for $MY_EMAIL..."

    # In 2026, 'op account add' is the preferred way to link the CLI.
    # Note: If the 1Password App is running with CLI Integration enabled,
    # this will automatically handshake with the app.

    echo "Decrypting Secret Key and adding 1Password account..."

    # Decrypt the key using chezmoi's built-in engine and pipe to 'op'
    # We use the 'decrypt' template function
    SECRET_KEY="{{ include "encrypted_secret_key.age" | decrypt }}"

    echo "$SECRET_KEY" | op account add \
        --address my.1password.com \
        --email "$MY_EMAIL" \
        --shorthand "$ACCOUNT_SHORTHAND" \
        --signin

    echo "✓ 1Password account added. Please perform the biometric handshake in the app."
fi

# 4. Final Verification
echo "Verifying 1Password CLI session..."
if op whoami &> /dev/null; then
    echo "✓ 1Password CLI is authenticated and ready."
else
    echo "Please run 'op signin' to complete your first biometric handshake."
fi
